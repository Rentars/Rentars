# Server
PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Authentication
# Must be a strong random secret (min 32 chars). Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_min_32_chars
# Access tokens expire in 15 minutes. Refresh tokens expire in 7 days.
# POST /auth/refresh with { refreshToken } to obtain new tokens.
# POST /auth/logout  with { refreshToken } (+ Bearer token) to revoke both.

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3001

# Redis
REDIS_URL=redis://localhost:6379

# Stellar / Soroban
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Contract IDs (set after deployment)
PROPERTY_LISTING_CONTRACT_ID=your_property_listing_contract_id
BOOKING_CONTRACT_ID=your_booking_contract_id

# TrustlessWork escrow API
TRUSTLESS_WORK_API_URL=https://api.trustlesswork.com
TRUSTLESS_WORK_API_KEY=your_trustless_work_api_key

# Redis
REDIS_URL=redis://localhost:6379

# Geocoding (optional — defaults to OpenStreetMap Nominatim when not set)
GEOCODING_API_KEY=your_geocoding_api_key

# Email (optional — transactional emails via SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=Rentars <no-reply@rentars.app>
